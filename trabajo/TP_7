#Ejercicio Nro 8

stock = {
    "Lapiz": 10,
    "Cuaderno": 5
}

producto = input("Ingrese un producto: ").title()

while producto == "":

    print("Debe ingresar un producto")
    producto = input("Ingrese un producto: ").title()

if producto in stock:

    print("Stock actual:", stock[producto])

    agregar = int(input("Cantidad a agregar: "))

    stock[producto] += agregar

    print("Nuevo stock:", stock[producto])

else:

    cantidad = int(input("Producto nuevo. Ingrese stock inicial: "))

    stock[producto] = cantidad

print(stock)

